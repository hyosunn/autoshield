# Copy this file to .env and fill in your values
# .env is gitignored and should never be committed

FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=true
FLASK_PORT=5000

# Optional: override the default dataset path (apps/static/data/SFdata.csv)
# DATASET_PATH=/absolute/path/to/SFdata.csv
